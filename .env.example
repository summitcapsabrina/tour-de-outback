# Square donation checkout — Vercel environment variables.
# Copy these keys into the Vercel project's Settings → Environment Variables.
# NEVER commit real values. The access token is a secret.

SQUARE_ACCESS_TOKEN=   # secret; Sandbox token starts with EAAA…  (paste in Vercel only)
SQUARE_LOCATION_ID=    # e.g. L… (Sandbox location)
SQUARE_ENV=sandbox     # "sandbox" while testing, "production" when live
# SQUARE_VERSION=2024-12-18   # optional override of the Square API version
